# Copy to can_telem.conf and adjust paths. Lines starting with # are comments.
# Keys are case-insensitive. CLI flags (-i, -f, -o) override these values.

output_dir = /var/tmp/can_telem_logs
format_file = ./sc-data-format/format.json
can_interface = can0

# --- Optional: InfluxDB Cloud (HTTPS write API v2) ---
# CSV logs are still written on every decoded CAN update.
# Influx uploads run at influx_upload_interval_ms: non-bool fields use the
# arithmetic mean over the window; bool fields use logical OR (true if any
# sample in the window was true).
#
# influx_enabled = true
# influx_url = https://us-east-1-1.aws.cloud2.influxdata.com
# influx_org = your-org
# influx_bucket = your-bucket
# influx_token = paste-token-here
# Or omit influx_token and run: export INFLUX_TOKEN=...
# influx_upload_interval_ms = 1000
# Production mobile app contract:
#   telemetry_snapshot,signal=<name> value=<number>
# Keep this unset to use the default telemetry_snapshot measurement, or set it
# explicitly for clarity.
# influx_measurement = telemetry_snapshot

# --- Optional: DB-driven CAN transmit (SQLite) ---
# Enable this to poll values from a SQLite DB and transmit updates on CAN for
# signals marked with source="db" in format.json.
#
# db_enabled = true
# db_path = /var/lib/can_telem/can_telem.db
# db_table = signal_values
# db_key_column = signal_key
# db_value_column = signal_value
# db_poll_interval_ms = 200
# db_can_interface = can0

# --- Optional: Serial radio telemetry ---
# When enabled, the latest decoded value for every active signal is written
# to the serial device once per radio_flush_interval_ms in the format:
#   <timestamp_ns>,<signal_name>,<value>
# The radio shares the same poll loop as InfluxDB so it adds no extra threads.
#
# radio_enabled = true
# radio_device = /dev/ttyUSB0
# radio_baud = 9600
# radio_flush_interval_ms = 1000

# --- Optional: signal role filters (without editing sc-data-format) ---
# Comma-separated signal names. Leave empty/missing to allow all.
# rx_signals = pack_voltage,pack_current,soc,lat,lon,elev
# tx_signals = torque_cmd,drive_mode

# --- Optional: GNSS merge ---
# Pull lat/lon/elev from /run/can_telem/gnss.json (written by gnss_service.py)
# gnss_enabled = true
# gnss_poll_interval_ms = 1000
# gnss_cache_path = /run/can_telem/gnss.json
# gnss_lat_signal = lat
# gnss_lon_signal = lon
# gnss_elev_signal = elev
